---
// Font faces, self-hosted via @fontsource. Only the weights the design uses.
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/700.css";
import "@fontsource/archivo/800.css";
import "@fontsource/archivo/900.css";
import "@fontsource/newsreader/400.css";
import "@fontsource/newsreader/500.css";
import "@fontsource/newsreader/400-italic.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tanya Singh · Strategy / Research / Creator Marketing",
  description = "Strategist. Simplifying complex findings, spotting cultural patterns, and grounding strategy in evidence.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (p: string) => `${base}/${p}`;
const faviconPath = withBase("favicon.svg");
const ogPath = withBase("og.png");
const canonicalURL = Astro.site ? new URL(`${base}/`, Astro.site).href : undefined;
const ogImageURL = Astro.site ? new URL(ogPath, Astro.site).href : ogPath;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    <meta name="theme-color" content="#F2EEE3" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tanya Singh" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <slot />
  </body>
</html>
