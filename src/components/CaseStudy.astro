---
import type { CaseStudy } from "../data/cases.ts";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<article class="case">
  <h3 class="client font-display">{data.client}</h3>
  <div class="role font-mono">{data.role}</div>

  <div class="formula">
    <div class="row">
      <span class="tag font-mono">Tension</span>
      <p>{data.tension}</p>
    </div>
    <div class="row">
      <span class="tag font-mono">Cultural pattern</span>
      <p>{data.pattern}</p>
    </div>
    <div class="row result">
      <span class="tag font-mono">Strategy</span>
      <p>{data.strategy}</p>
    </div>
  </div>

  {data.metrics && (
    <div class="metrics">
      {data.metrics.map((m) => (
        <div class="m">
          <div class="big font-display">{m.big}</div>
          <div class="cap font-mono">{m.cap}</div>
        </div>
      ))}
    </div>
  )}

  <p class="accounts font-mono">
    {data.accounts.label} <b>{data.accounts.bold}</b>{data.accounts.tail}
  </p>
</article>

<style>
  .case {
    padding: 40px 0;
    border-top: 1px solid var(--rule);
  }
  .case:first-of-type {
    border-top: 0;
  }
  .client {
    font-weight: 900;
    font-size: clamp(28px, 4vw, 56px);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .role {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-top: 8px;
  }
  .formula {
    margin-top: 28px;
    border: 1px solid var(--rule);
  }
  .row {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 20px;
    padding: 18px 20px;
    border-top: 1px solid var(--rule);
  }
  .row:first-child {
    border-top: 0;
  }
  .tag {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-red-text);
    padding-top: 4px;
  }
  .row.result .tag {
    color: var(--color-ink);
  }
  .row p {
    font-size: 18px;
    line-height: 1.4;
  }
  .row.result p {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: clamp(18px, 2vw, 24px);
  }
  .metrics {
    display: flex;
    flex-wrap: wrap;
    margin-top: 24px;
    border: 2px solid var(--color-ink);
  }
  .m {
    flex: 1 1 150px;
    padding: 20px;
    border-right: 1px solid var(--rule);
  }
  .m:last-child {
    border-right: 0;
  }
  .big {
    font-weight: 900;
    font-size: clamp(24px, 3vw, 38px);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .cap {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-top: 8px;
    line-height: 1.3;
  }
  .accounts {
    margin-top: 22px;
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.02em;
    line-height: 1.5;
  }
  .accounts b {
    color: var(--color-ink);
  }

  @media (max-width: 600px) {
    .row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    /* Stack metric boxes into a single column so the numbers never squish. */
    .metrics {
      flex-direction: column;
    }
    .m {
      flex: 1 1 auto;
      border-right: 0;
      border-bottom: 1px solid var(--rule);
    }
    .m:last-child {
      border-bottom: 0;
    }
  }
</style>
