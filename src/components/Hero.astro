---
import MarginRail from "./MarginRail.astro";
---

<header id="top">
  <div class="wrap">
    <div class="hero-top reveal">
      <span class="eyebrow">Strategy / Research / Creator Marketing</span>
      <span class="eyebrow">Bengaluru, India</span>
    </div>

    <h1 class="statement font-display reveal d1">
      Simplifying complex findings, spotting cultural patterns, and grounding
      strategy in <span class="hl">evidence.</span>
    </h1>
    <MarginRail>Statement · 11 words · zero filler</MarginRail>

    <p class="subhook reveal d2">
      Most marketing sounds like a <span class="machine">machine</span>. I build
      systems and strategies to fix that.
    </p>
    <MarginRail>Struck "machine" — that's the whole point</MarginRail>

    <div class="hero-foot reveal d3">
      <div><div class="k font-mono">Started in</div><div class="v font-display">Qualitative research</div></div>
      <div><div class="k font-mono">Now</div><div class="v font-display">Brand Lead, SOLO</div></div>
      <div><div class="k font-mono">Built for</div><div class="v font-display">Brands + creators</div></div>
    </div>
  </div>
</header>

<style>
  header {
    padding: 72px 0 64px;
    border-bottom: 2px solid var(--color-ink);
  }
  .hero-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 42px;
  }
  .statement {
    font-size: var(--text-display-xl);
    max-width: 16ch;
    margin: 18px 0 0;
  }
  .statement .hl {
    color: var(--color-red);
  }
  .subhook {
    font-size: var(--text-lede);
    line-height: 1.3;
    max-width: 24ch;
    margin-top: 40px;
    font-weight: 500;
  }
  .machine {
    position: relative;
    display: inline-block;
  }
  .machine::after {
    content: "";
    position: absolute;
    left: -2px;
    right: -2px;
    top: 54%;
    height: 3px;
    background: var(--color-red);
    transform: scaleX(1);
    transform-origin: left;
  }
  .hero-foot {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
    margin-top: 54px;
  }
  .hero-foot .k {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .hero-foot .v {
    font-weight: 800;
    font-size: 18px;
    margin-top: 4px;
  }

  /* Orchestrated load + machine strike: only when motion is welcome.
     Default (reduced motion) keeps everything visible and pre-struck. */
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(14px);
      animation: rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }
    .reveal.d1 { animation-delay: 0.12s; }
    .reveal.d2 { animation-delay: 0.24s; }
    .reveal.d3 { animation-delay: 0.36s; }

    .machine::after {
      transform: scaleX(0);
      animation: strike 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) 1s forwards;
    }
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes strike {
    to {
      transform: scaleX(1);
    }
  }
</style>
