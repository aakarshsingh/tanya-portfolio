---
import fs from "node:fs";
import path from "node:path";
import { siTinder, siIkea, siBurgerking, siNissan, siVivo } from "simple-icons";
import { brands } from "../data/brands.ts";
import MarginRail from "./MarginRail.astro";

interface Mark {
  path: string;
  title: string;
}

const ICONS: Record<string, Mark> = {
  siTinder,
  siIkea,
  siBurgerking,
  siNissan,
  siVivo,
};

// Any SVG dropped into public/logos/<slug>.svg is auto-used and masked to
// ink (works for colour or B/W sources). Falls back to a simple-icons mark,
// then to an Archivo wordmark.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const logosDir = path.join(process.cwd(), "public", "logos");
let dropped = new Set<string>();
try {
  dropped = new Set(
    fs
      .readdirSync(logosDir)
      .filter((f) => f.endsWith(".svg"))
      .map((f) => f.slice(0, -4)),
  );
} catch {
  // no logos directory yet
}

const pad = (n: number) => String(n + 1).padStart(2, "0");
const logoUrl = (slug: string) => `${base}/logos/${slug}.svg`;
---

<section id="brands">
  <div class="wrap">
    <div class="sec-head">
      <span class="num">03</span>
      <h2>Brands I've built for.</h2>
    </div>

    <ul class="ledger">
      {brands.map((b, i) => {
        const icon = b.iconKey ? ICONS[b.iconKey] : undefined;
        const hasFile = dropped.has(b.slug);
        return (
          <li class="cell">
            <span class="idx font-mono">{pad(i)}</span>
            {hasFile ? (
              <span
                class="logo-mask"
                style={`--src:url('${logoUrl(b.slug)}')`}
                role="img"
                aria-label={b.name}
              ></span>
            ) : icon ? (
              <svg class="logo" viewBox="0 0 24 24" role="img" aria-label={b.name}>
                <title>{b.name}</title>
                <path d={icon.path} />
              </svg>
            ) : (
              <span class="wordmark font-display">{b.name}</span>
            )}
          </li>
        );
      })}
    </ul>

    <p class="more font-mono">&amp; many more.</p>

    <MarginRail>{brands.length} brands · research to creator marketing</MarginRail>
  </div>
</section>

<style>
  /* Border-based hairlines (not a gap-fill) so trailing empty cells show
     paper, never a grey block. */
  .ledger {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    background: var(--color-paper);
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .cell {
    position: relative;
    background: var(--color-paper);
    min-height: 122px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s, box-shadow 0.15s;
  }
  .cell:hover {
    background: var(--color-paper-raise);
    box-shadow: inset 0 -2px 0 var(--color-red);
  }
  .more {
    margin-top: 18px;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .idx {
    position: absolute;
    top: 10px;
    left: 12px;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
  }
  .logo {
    width: auto;
    height: 34px;
    color: var(--color-ink);
    fill: currentColor;
    transition: color 0.15s;
  }
  .cell:hover .logo {
    color: var(--color-red);
  }
  /* Dropped-in SVGs: masked to a uniform ink silhouette regardless of source colour. */
  .logo-mask {
    display: block;
    width: 130px;
    max-width: 78%;
    height: 34px;
    background-color: var(--color-ink);
    -webkit-mask: var(--src) center / contain no-repeat;
    mask: var(--src) center / contain no-repeat;
    transition: background-color 0.15s;
  }
  .cell:hover .logo-mask {
    background-color: var(--color-red);
  }
  .wordmark {
    font-weight: 800;
    font-size: clamp(16px, 1.6vw, 20px);
    letter-spacing: -0.01em;
    text-align: center;
    line-height: 1.05;
    color: var(--color-ink);
    transition: color 0.15s;
  }
  .cell:hover .wordmark {
    color: var(--color-red);
  }
</style>
