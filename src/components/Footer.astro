---
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap foot-inner font-mono">
    <span>© {year} Tanya Singh</span>
    <span>Strategy without the fluff.</span>
  </div>
</footer>

<style>
  footer {
    padding: 40px 0;
    border-top: 1px solid var(--color-ink);
  }
  .foot-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-ink-soft);
  }
</style>
