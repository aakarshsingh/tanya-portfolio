---
import { reframes } from "../data/reframes.ts";
import MarginRail from "./MarginRail.astro";
---

<section id="reframe">
  <div class="wrap">
    <div class="sec-head">
      <span class="num">01</span>
      <h2>I don't make copy longer. I make it land.</h2>
    </div>

    <div class="engine" id="engine">
      <div class="label">
        <span class="dot" aria-hidden="true"></span>
        <span class="eyebrow">The Obvious</span>
      </div>
      <div class="obv-wrap">
        <span class="obv" id="obvText"></span>
      </div>
      <div class="reframe font-display" id="reframeText" aria-live="polite"></div>
      <div class="controls">
        <button class="btn" id="reframeBtn" type="button">Reframe it</button>
        <button class="btn ghost" id="nextBtn" type="button">Next example <span aria-hidden="true">→</span></button>
      </div>
      <div class="meter font-mono" id="meter" aria-live="polite"></div>
    </div>

    <MarginRail>Live word count — proof it lands, not just shorter</MarginRail>
  </div>

  <script type="application/json" id="reframe-data" is:inline set:html={JSON.stringify(reframes)} />
</section>

<style>
  .engine {
    border: 2px solid var(--color-ink);
    background: var(--color-card);
    padding: clamp(24px, 4vw, 52px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }
  .label {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }
  .dot {
    width: 9px;
    height: 9px;
    background: var(--color-red);
    border-radius: 50%;
  }
  .obv-wrap {
    padding: 8px 0 4px;
  }
  .obv {
    font-size: clamp(19px, 2vw, 24px);
    color: #4f4a40;
    line-height: 1.5;
    font-style: italic;
    /* Real per-line strikethrough so it crosses every wrapped line.
       Hidden (transparent) until struck, then the red pen fades in. */
    text-decoration-line: line-through;
    text-decoration-color: transparent;
    text-decoration-thickness: 3px;
    transition: text-decoration-color 0.45s ease, color 0.4s ease;
  }
  .engine.struck .obv {
    color: #8a8475;
    text-decoration-color: var(--color-red);
  }
  .reframe {
    font-weight: 800;
    line-height: 1.05;
    font-size: clamp(26px, 3.6vw, 46px);
    margin-top: 26px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(12px);
    transition: opacity 0.45s ease, transform 0.45s ease, max-height 0.5s ease;
  }
  .engine.struck .reframe {
    max-height: 600px;
    opacity: 1;
    transform: none;
  }
  .controls {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .meter {
    font-size: 12px;
    color: var(--color-ink-soft);
    margin-top: 18px;
    letter-spacing: 0.04em;
  }
</style>

<script>
  interface Pair {
    obvious: string;
    reframe: string;
  }

  const dataEl = document.getElementById("reframe-data");
  const pairs: Pair[] = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

  const engine = document.getElementById("engine");
  const obvEl = document.getElementById("obvText");
  const reEl = document.getElementById("reframeText");
  const btn = document.getElementById("reframeBtn");
  const nextBtn = document.getElementById("nextBtn");
  const meter = document.getElementById("meter");

  let i = 0;
  let interacted = false;
  let autoTimer: number | undefined;

  const wc = (s: string): number => s.trim().split(/\s+/).filter(Boolean).length;

  function setMeter(struck: boolean): void {
    if (!meter || pairs.length === 0) return;
    const o = wc(pairs[i].obvious);
    const r = wc(pairs[i].reframe);
    const cut = Math.round((1 - r / o) * 100);
    meter.textContent = struck
      ? `${o} words → ${r} words · ${cut}% cut`
      : `${o} words · before`;
  }

  function render(): void {
    if (pairs.length === 0) return;
    if (obvEl) obvEl.textContent = pairs[i].obvious;
    if (reEl) reEl.textContent = pairs[i].reframe;
    setMeter(engine?.classList.contains("struck") ?? false);
  }

  function setStruck(on: boolean): void {
    engine?.classList.toggle("struck", on);
    if (btn) btn.textContent = on ? "Show the obvious" : "Reframe it";
    setMeter(on);
  }

  btn?.addEventListener("click", () => {
    interacted = true;
    window.clearTimeout(autoTimer);
    setStruck(!(engine?.classList.contains("struck") ?? false));
  });

  nextBtn?.addEventListener("click", () => {
    if (pairs.length === 0) return;
    interacted = true;
    window.clearTimeout(autoTimer);
    i = (i + 1) % pairs.length;
    setStruck(false);
    render();
  });

  render();

  // Auto-demo: strike the first example once when the engine scrolls into
  // view, so passive readers still see the proof. Skipped for reduced
  // motion; cancelled the moment the visitor interacts themselves.
  const motionOK = window.matchMedia("(prefers-reduced-motion: no-preference)").matches;
  if (motionOK && engine && pairs.length > 0) {
    const io = new IntersectionObserver(
      (entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        io.disconnect();
        autoTimer = window.setTimeout(() => {
          if (!interacted && !engine.classList.contains("struck")) setStruck(true);
        }, 900);
      },
      { threshold: 0.45 },
    );
    io.observe(engine);
  }
</script>
